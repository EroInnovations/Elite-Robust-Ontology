<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Allow access to the app's external files directory -->
    <external-files-path
        name="external_files"
        path="." />

    <!-- Allow access to the Pictures directory -->
    <external-files-path
        name="images"
        path="Pictures/" />

    <!-- Allow access to Downloads directory -->
    <external-path
        name="downloads"
        path="Download/" />

    <!-- Allow access to documents directory -->
    <external-path
        name="documents"
        path="Documents/" />
</paths>
